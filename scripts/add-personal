#!/usr/bin/env bash
# Register a personal Claude account for one OIDC user, by running
# `claude /login` against that user's per-user CLAUDE_CONFIG_DIR.
#
# Usage:
#   ./scripts/add-personal --sub <oidc-sub> [--label "<display name>"]
#
# Environment:
#   CLAUDE_WEB_CONTAINER   docker container name (default: claude-web)
#
# This is the host-side wrapper. It just docker-execs into the running
# container; the real work happens in scripts/add_personal_inside.py.
set -euo pipefail

CONTAINER="${CLAUDE_WEB_CONTAINER:-claude-web}"

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
  echo "claude-web container '$CONTAINER' not found." >&2
  echo "Set CLAUDE_WEB_CONTAINER if your container is named differently." >&2
  exit 1
fi

exec docker exec -it "$CONTAINER" python /app/scripts/add_personal_inside.py "$@"
