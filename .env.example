# ─── Auth ────────────────────────────────────────────────────────────────────
# "oidc" (recommended) or "none" (no auth -- only safe for localhost dev).
AUTH_MODE=oidc

# Random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me

# OIDC provider details. Issuer URL is the base your IdP advertises in
# /.well-known/openid-configuration. Examples:
#   Keycloak:  https://auth.example.com/realms/main
#   Authentik: https://auth.example.com/application/o/<slug>/
#   Auth0:     https://your-tenant.auth0.com/
OIDC_ISSUER_URL=https://auth.example.com/realms/main
OIDC_CLIENT_ID=claude-web
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=https://claude.example.com/auth/callback

# Optional: restrict who can sign in. Empty = anyone with a valid token.
# OIDC_ALLOWED_EMAILS=you@example.com,partner@example.com
# OIDC_ALLOWED_GROUPS=admins,family

# Set to "true" only if you're testing over plain HTTP (e.g. localhost).
# SESSION_COOKIE_INSECURE=false

# ─── Claude Code ─────────────────────────────────────────────────────────────
# Project root inside the container. Mount your code at this path.
CLAUDE_PROJECT_DIR=/workspace

# Tools auto-approved without showing a permission card. Comma-separated.
# SAFE_TOOLS=TodoWrite
