# ─── Auth ────────────────────────────────────────────────────────────────────
# "oidc" (recommended) or "none" (no auth -- only safe for localhost dev or
# behind a trusted upstream proxy doing the gating).
AUTH_MODE=oidc

# Random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me

# OIDC provider details. Issuer URL is the base your IdP advertises in
# /.well-known/openid-configuration. Examples:
#   Keycloak:  https://auth.example.com/realms/main
#   Authentik: https://auth.example.com/application/o/<slug>/
#   Auth0:     https://your-tenant.auth0.com/
OIDC_ISSUER_URL=https://auth.example.com/realms/main
OIDC_CLIENT_ID=claude-web
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=https://claude.example.com/auth/callback

# Optional: restrict who can sign in. Empty = anyone with a valid token.
# OIDC_ALLOWED_EMAILS=you@example.com,partner@example.com
# OIDC_ALLOWED_GROUPS=admins,family

# Set to "true" only if you're testing over plain HTTP (e.g. localhost).
# SESSION_COOKIE_INSECURE=false

# How long the signed session cookie is valid. Default 24h.
# SESSION_MAX_AGE_SECONDS=86400

# ─── Claude Code ─────────────────────────────────────────────────────────────
# Project root inside the container. Mount your code at this path.
CLAUDE_PROJECT_DIR=/workspace

# Optional: comma-separated list of project roots for the project picker.
# CLAUDE_WEB_PROJECT_DIRS=/workspace,/notes

# Tools auto-approved without showing a permission card. Comma-separated.
# SAFE_TOOLS=TodoWrite

# Tools where "Allow this session" is intentionally disabled because their
# signature is too coarse to be safe (e.g. allowing `echo` would also bless
# `echo "ok" && rm -rf ~`). Each call requires explicit per-call approval.
# NO_SESSION_ALLOWLIST_TOOLS=Bash

# Optional: model the CLI retries with when the primary is overloaded
# (API 529). Unset = no fallback.
# CLAUDE_WEB_FALLBACK_MODEL=claude-sonnet-4-6

# Optional: hard per-run API-spend ceiling in USD. Only meaningful for
# API-key credentials — subscription turns report synthetic costs. 0 = off.
# CLAUDE_WEB_MAX_BUDGET_USD=0

# Optional: Pushover notification when a turn runs longer than
# CLAUDE_WEB_NOTIFY_MIN_SECONDS (default 120). Both vars required to enable.
# CLAUDE_WEB_PUSHOVER_TOKEN=
# CLAUDE_WEB_PUSHOVER_USER=
# CLAUDE_WEB_NOTIFY_MIN_SECONDS=120

# File checkpointing: lets /rewind restore files to a pre-turn state.
# On by default; set false to skip the per-edit snapshot overhead.
# CLAUDE_WEB_FILE_CHECKPOINTS=true

# Drain-restart ceiling: how long /api/admin/restart (or SIGUSR1) waits for
# busy conversations before restarting anyway. See README "Self-restart".
# CLAUDE_WEB_RESTART_MAX_WAIT=1800

# ─── Multi-user (NOT a security boundary — see README) ───────────────────────
# CLAUDE_WEB_PER_USER_SESSIONS=false
# CLAUDE_WEB_ADMIN_EMAILS=you@example.com

# ─── Setup-flow lock ─────────────────────────────────────────────────────────
# "auto" (default) allows /setup actions only while no credential exists; once
# Claude is signed in, the destructive endpoints lock until you flip this.
# "true"  → always allow (use during initial deploy or to switch accounts)
# "false" → always block (admin must shell into the container)
# CLAUDE_WEB_ENABLE_SETUP=auto

# ─── Hardening ───────────────────────────────────────────────────────────────
# Reject mutating requests without a matching Origin or Referer header.
# Disable only for command-line testing.
# CLAUDE_WEB_CSRF_STRICT=true

# Bound on per-subscriber SSE event queue. Slow clients are dropped (with an
# `_overflow` marker) instead of growing memory.
# CLAUDE_WEB_MAX_SUBSCRIBER_QUEUE=1000

# ─── Retention / GC ──────────────────────────────────────────────────────────
# CLAUDE_WEB_PERSIST_RETENTION=86400
# CLAUDE_WEB_UPLOAD_RETENTION=604800
# CLAUDE_WEB_PERMISSION_TIMEOUT=900
# CLAUDE_WEB_MAX_AUTO_FIRES=3
